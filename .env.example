# ECHO FORGE — Environment Template
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev — no Postgres needed)
DATABASE_URL=sqlite+aiosqlite:///./echoforge.db

# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/echoforge

# ── Polygon.io ────────────────────────────────────────────────────────────────
# When set, ECHO FORGE fetches live OHLCV from Polygon instead of synthetic data.
# Free tier supports most equity + crypto tickers.
POLYGON_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
ECHO_FORGE_DEBUG=false
